# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# Куда писать БД. В docker-compose переопределяется на /data/termloop.db
DATABASE_URL=sqlite+aiosqlite:///./data/termloop.db

# Общее расписание напоминаний (локальное время TIMEZONE), через запятую
REVIEW_TIMES=10:00,19:00
TIMEZONE=Europe/Moscow

# TTL незавершённой попытки, минуты
PENDING_TTL_MINUTES=30

# Ограниченная параллельность рассылки scheduler
SCHEDULER_CONCURRENCY=5

# Необязательный allowlist Telegram ID через запятую. Пусто = пускать всех.
ALLOWED_TELEGRAM_IDS=

# --- MCP-сервер (termloop-mcp) ---
# Чей словарь пополняют MCP-инструменты: твой Telegram ID (обязательно для MCP)
MCP_TELEGRAM_USER_ID=
# Bearer-токен для доступа к MCP. Пусто = без аутентификации (не рекомендуется).
MCP_AUTH_TOKEN=
MCP_HOST=0.0.0.0
MCP_PORT=8210
